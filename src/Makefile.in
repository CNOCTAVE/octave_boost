FLAGGED_MKOCTFILE = @MKOCTFILE@ @XTRA_CXXFLAGS@

## We can't link oct files, and Octave's package system does not handle
## shared libraries. Because of this, we need to create object files for
## our "shared" libraries and statically link to selected oct files.

## All Boost.Accumulators oct files are header-only, no separate library needed.
## The $(BOOST_CPPFLAGS) variable is set by configure.
BOOST_OCT_FILES = \
  boost_accumulators_coherent_tail_mean.oct \
  boost_accumulators_count.oct \
