BOOST_PROPERTY_TREE_OCT_FILES = \
  boost_info_file_to_ini_file.oct \
  boost_ini_file_to_info_file.oct \
  boost_info_file_to_json_file.oct \
  boost_json_file_to_info_file.oct \
  boost_info_file_to_xml_file.oct \
  boost_xml_file_to_info_file.oct \
  boost_ini_file_to_json_file.oct \
  boost_json_file_to_ini_file.oct \
  boost_ini_file_to_xml_file.oct \
  boost_xml_file_to_ini_file.oct \
  boost_json_file_to_xml_file.oct \
  boost_xml_file_to_json_file.oct \
  boost_save_as_info_file.oct \
  boost_save_as_ini_file.oct \
  boost_save_as_json_file.oct \
  boost_save_as_xml_file.oct \
  boost_parse_from_info_file.oct \
  boost_parse_from_ini_file.oct \
  boost_parse_from_json_file.oct \
  boost_parse_from_xml_file.oct

BOOST_THREAD_OCT_FILES = \
  boost_multi_thread_run_octave_file.oct \
  boost_multi_thread_run_octave_files.oct \
  boost_multi_thread_call_octave_function.oct \
  boost_multi_thread_call_octave_functions.oct \
  boost_multi_thread_eval_octave_expression.oct \
  boost_multi_thread_eval_octave_expressions.oct \
  boost_multi_thread_feval_octave_expression.oct \
  boost_multi_thread_feval_octave_expressions.oct

ALL_OCT_FILES = ${BOOST_OCT_FILES} ${BOOST_CHRONO_OCT_FILES} ${BOOST_PROPERTY_TREE_OCT_FILES} ${BOOST_THREAD_OCT_FILES}

# M_FILES are pre-installed in ../inst/, not built from src/
all: ${ALL_OCT_FILES}

# Boost accumulators are header-only, no separate library needed.
# The $(BOOST_CPPFLAGS) variable is set by configure.
boost_accumulators_%.oct: boost_accumulators_%.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

# Boost chrono clocks require -lboost_chrono (clock::now() is NOT header-only on Linux)
BOOST_CHRONO_LIBS = -lboost_chrono

boost_chrono_duration_%.oct: boost_chrono_duration_%.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_chrono_%.oct: boost_chrono_%.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_process_cpu_clock_now.oct: boost_process_cpu_clock_now.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_thread_clock_now.oct: boost_thread_clock_now.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_chrono_system_clock_duration.oct: boost_chrono_system_clock_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_chrono_steady_clock_duration.oct: boost_chrono_steady_clock_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_chrono_high_resolution_clock_duration.oct: boost_chrono_high_resolution_clock_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_process_cpu_clock_duration.oct: boost_process_cpu_clock_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_thread_clock_duration.oct: boost_thread_clock_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_time_fmt_duration.oct: boost_time_fmt_duration.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

boost_time_fmt_system_clock.oct: boost_time_fmt_system_clock.cc
	$(FLAGGED_MKOCTFILE) $(BOOST_CHRONO_LIBS) $< $(BOOST_CPPFLAGS)

# Boost date_time is header-only (boost/date_time/gregorian/gregorian.hpp), no separate library needed.
boost_date_%.oct: boost_date_%.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_ptime_%.oct: boost_ptime_%.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_time_duration_%.oct: boost_time_duration_%.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_time_period_%.oct: boost_time_period_%.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

# Boost property_tree is also header-only, no separate library needed.
boost_info_file_to_ini_file.oct: boost_info_file_to_ini_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_ini_file_to_info_file.oct: boost_ini_file_to_info_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_info_file_to_json_file.oct: boost_info_file_to_json_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_json_file_to_info_file.oct: boost_json_file_to_info_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_info_file_to_xml_file.oct: boost_info_file_to_xml_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_xml_file_to_info_file.oct: boost_xml_file_to_info_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_ini_file_to_json_file.oct: boost_ini_file_to_json_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_json_file_to_ini_file.oct: boost_json_file_to_ini_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_ini_file_to_xml_file.oct: boost_ini_file_to_xml_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_xml_file_to_ini_file.oct: boost_xml_file_to_ini_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_json_file_to_xml_file.oct: boost_json_file_to_xml_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_xml_file_to_json_file.oct: boost_xml_file_to_json_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_save_as_info_file.oct: boost_save_as_info_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_save_as_ini_file.oct: boost_save_as_ini_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_save_as_json_file.oct: boost_save_as_json_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_save_as_xml_file.oct: boost_save_as_xml_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_parse_from_info_file.oct: boost_parse_from_info_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_parse_from_ini_file.oct: boost_parse_from_ini_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_parse_from_json_file.oct: boost_parse_from_json_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

boost_parse_from_xml_file.oct: boost_parse_from_xml_file.cc
	$(FLAGGED_MKOCTFILE) $< $(BOOST_CPPFLAGS)

# Boost thread requires linking with the Boost thread library.
boost_multi_thread_%.oct: boost_multi_thread_%.cc
	$(FLAGGED_MKOCTFILE) -lboost_thread $< $(BOOST_CPPFLAGS)

clean:
	$(RM) *.o octave-core octave-workspace *~ ${ALL_OCT_FILES}
