  boost_accumulators_weighted_extended_p_square.oct \
  boost_accumulators_weighted_kurtosis.oct \
  boost_accumulators_weighted_mean_and_variants.oct \
  boost_accumulators_weighted_median_and_variants.oct \
  boost_accumulators_weighted_moment.oct \
  boost_accumulators_weighted_p_square_cumulative_distribution.oct \
  boost_accumulators_weighted_p_square_quantile_and_variants.oct \
  boost_accumulators_weighted_peaks_over_threshold_and_variants.oct \
  boost_accumulators_weighted_skewness.oct \
  boost_accumulators_weighted_sum_and_variants.oct \
  boost_accumulators_non_coherent_weighted_tail_mean.oct \
  boost_accumulators_weighted_tail_quantile.oct \
