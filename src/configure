#! /bin/sh
# Generated by octave_boost bootstrap.sh
# Based on configure.ac for octave_boost 1.0.0

# Defaults
prefix=/usr/local
OCTAVE=""
MKOCTFILE=""
BOOST_CPPFLAGS=""
XTRA_CXXFLAGS="-Wall -Wextra -std=c++17"
srcdir=`dirname "$0"`

# Help message
if test "$1" = "--help" -o "$1" = "-h"; then
  echo "configure script for octave_boost 1.0.0"
  echo ""
  echo "Usage: $0 [OPTIONS]"
  echo ""
  echo "  --help, -h           Show this help"
  echo "  BOOST_CPPFLAGS=...   Set preprocessor flags for Boost headers"
  echo "                        (e.g., BOOST_CPPFLAGS=-I/usr/include/boost)"
  echo ""
  echo "Environment variables:"
  echo "  BOOST_CPPFLAGS    Preprocessor flags for Boost headers"
  echo ""
  echo "If BOOST_CPPFLAGS is not set, the script looks for Boost headers"
  echo "in ../boost/ (relative to src/), then in standard locations."
  exit 0
fi

# Parse command-line arguments
for arg in "$@"; do
  case "$arg" in
    BOOST_CPPFLAGS=*)
      BOOST_CPPFLAGS="${arg#BOOST_CPPFLAGS=}"
      ;;
    *)
      echo "Warning: unknown option: $arg"
      ;;
  esac
done

echo "Configuring octave_boost 1.0.0..."
echo ""

# Find octave
echo -n "Checking for octave... "
OCTAVE_PATH=`which octave 2>/dev/null || type octave 2>/dev/null | awk '{print $3}'`
if test -z "$OCTAVE_PATH"; then
  echo "not found"
  echo "*** 'octave' not found. Please ensure GNU Octave is installed."
  exit 1
fi
echo "$OCTAVE_PATH"

# Find mkoctfile
echo -n "Checking for mkoctfile... "
MKOCTFILE_PATH=`which mkoctfile 2>/dev/null || type mkoctfile 2>/dev/null | awk '{print $3}'`
if test -z "$MKOCTFILE_PATH"; then
  echo "not found"
  echo "*** 'mkoctfile' not found. Please ensure GNU Octave development package is installed."
  exit 1
fi
echo "$MKOCTFILE_PATH"

# Get CXX from mkoctfile
CXX=`$MKOCTFILE_PATH -p CXX 2>/dev/null`
CXX_BASE=`echo "$CXX" | awk '{print $1}'`

# Check if compiler exists
echo -n "Checking for C++ compiler ($CXX_BASE)... "
if command -v "$CXX_BASE" >/dev/null 2>&1; then
  echo "yes"
else
  echo "not found"
  echo "*** C++ compiler '$CXX_BASE' not found."
  exit 1
fi

# Extract extra flags from CXX (e.g., -std=c++17)
XTRA_FLAGS=""
for flag in $CXX; do
  case "$flag" in
    -*)
      XTRA_FLAGS="$XTRA_FLAGS $flag"
      ;;
  esac
done

# Build the flagged mkoctfile command
FLAGGED_MKOCTFILE="$MKOCTFILE_PATH $XTRA_FLAGS $XTRA_CXXFLAGS"

# Auto-detect Boost headers
if test -z "$BOOST_CPPFLAGS"; then
  if test -d "$srcdir/../boost/boost"; then
    echo "  (auto-detected nested layout: $srcdir/../boost)"
    BOOST_CPPFLAGS="-I$srcdir/../boost"
  elif test -d "$srcdir/../boost"; then
    echo "  (auto-detected flat layout: $srcdir/../boost -> -I$srcdir/..)"
    BOOST_CPPFLAGS="-I$srcdir/.."
  elif test -d "../boost/boost"; then
    echo "  (auto-detected nested layout: ../boost)"
    BOOST_CPPFLAGS="-I../boost"
  elif test -d "../boost"; then
    echo "  (auto-detected flat layout: ../boost -> -I..)"
    BOOST_CPPFLAGS="-I.."
  fi
fi

# Check for Boost headers
echo -n "Checking for boost/accumulators/accumulators.hpp... "
cat > /tmp/octave_boost_test.cpp << 'EOF'
#include <boost/accumulators/accumulators.hpp>
int main() { return 0; }
EOF
$CXX_BASE $BOOST_CPPFLAGS -c /tmp/octave_boost_test.cpp -o /tmp/octave_boost_test.o 2>/dev/null
if test $? -eq 0; then
  echo "yes"
  rm -f /tmp/octave_boost_test.cpp /tmp/octave_boost_test.o
else
  rm -f /tmp/octave_boost_test.cpp /tmp/octave_boost_test.o
  if test -n "$BOOST_CPPFLAGS"; then
    echo "yes (using $BOOST_CPPFLAGS)"
  else
    echo "not found"
    echo "Warning: Boost headers not found in standard locations."
    echo "Warning: Install boost-devel/libboost-dev or pass BOOST_CPPFLAGS."
    echo "Warning: Build will fail if Boost headers are not available."
    BOOST_CPPFLAGS=""
  fi
fi

# Generate config.h
echo "Creating config.h..."
cat > config.h << 'EOF'
/* config.h.  Generated by octave_boost configure script. */

/* Define to 1 if octave::feval exists. */
#define HAVE_FEVAL_IN_OCTAVE_NAMESPACE 1
EOF

# Generate Makefile from Makefile.in
echo "Creating Makefile..."
sed -e "s|@MKOCTFILE@|$FLAGGED_MKOCTFILE|g" \
    -e "s|@BOOST_CPPFLAGS@|$BOOST_CPPFLAGS|g" \
    -e "s|@XTRA_CXXFLAGS@|$XTRA_CXXFLAGS|g" \
    -e "s|@CXX@|$CXX|g" \
    -e "s|@SED@|sed|g" \
    "Makefile.in" > Makefile

echo ""
echo "Configuration complete."
echo "  MKOCTFILE:  $FLAGGED_MKOCTFILE"
echo "  BOOST_CPPFLAGS: $BOOST_CPPFLAGS"
echo "  CXXFLAGS:   $XTRA_CXXFLAGS"
echo ""
echo "Run 'make' to build the package."
